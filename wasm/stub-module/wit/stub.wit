package hermes:stub;

world stub {
    use wasi:http/types@0.2.6.{incoming-request, response-outparam};
    use hermes:cardano/api.{block, subscription-id};
    use hermes:cbor/api.{cbor};
    use hermes:ipfs/api.{pubsub-message};
    use hermes:kv-store/api.{kv-values};
    use hermes:binary/api.{bstr};
    use hermes:cron/api.{cron-tagged};
    use hermes:http-gateway/event.{headers, http-gateway-response};
    use hermes:integration-test/event.{test-result};

    // include hermes:wasi/hermes;

    import wasi:http/types@0.2.6;
    import hermes:binary/api;
    import hermes:cardano/api;
    import hermes:cbor/api;
    import hermes:cron/api;
    import hermes:crypto/api;
    import hermes:hash/api;
    import hermes:init/api;
    import hermes:ipfs/api;
    import hermes:json/api;
    import hermes:kv-store/api;
    import hermes:localtime/api;
    import hermes:logging/api;
    import hermes:sqlite/api;
    import hermes:http-request/api;

    // export hermes:init/event;
    // export hermes:kv-store/event;
    // export hermes:cron/event;
    // export hermes:cardano/event-on-block;
    // export hermes:cardano/event-on-immutable-roll-forward;
    // export hermes:ipfs/event;
    // export hermes:http-request/event;
    // export hermes:http-gateway/event;
    // export hermes:integration-test/event;
    // export wasi:http/incoming-handler@0.2.6;

    export init: func() -> bool;
    export kv-update: func(key: string, value: kv-values);
    export on-cron: func(event: cron-tagged, last: bool) -> bool;
    export on-cardano-block: func(subscription-id: borrow<subscription-id>, block: borrow<block>);
    export on-cardano-immutable-roll-forward: func(subscription-id: borrow<subscription-id>, block: borrow<block>);
    export on-topic: func(message: pubsub-message) -> bool;
    export on-http-response: func(request-id: option<u64>, response: list<u8>);
    export reply: func(body: bstr, headers: headers, path: string, method: string) -> option<http-gateway-response>;
    export test: func(test: u32, run: bool) -> option<test-result>;
    export bench: func(test: u32, run: bool) -> option<test-result>;
    export handle: func(request: incoming-request,response-out: response-outparam);
}
